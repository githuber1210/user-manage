# Auto detect text files and perform LF normalization
* text=auto

# Java files
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary